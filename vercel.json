{"$schema": "https://openapi.vercel.sh/vercel.json", "framework": "nextjs", "buildCommand": "npm run build", "outputDirectory": ".next", "installCommand": "npm install", "devCommand": "npm run dev", "regions": ["sin1"], "headers": [{"source": "/api/(.*)", "headers": [{"key": "Access-Control-Allow-Origin", "value": "*"}, {"key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS"}, {"key": "Access-Control-Allow-Headers", "value": "Content-Type, x-api-key, Authorization"}, {"key": "Access-Control-Max-Age", "value": "86400"}]}], "functions": {"src/app/api/**/*.ts": {"maxDuration": 900}}, "env": {"NEXT_PUBLIC_APP_NAME": "Discord Quest API", "NODE_ENV": "production"}}